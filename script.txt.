local function getUniversalTarget(range, specificName)
	local char = LocalPlayer.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not root then return nil, nil end
	
	local nearest, shortDist = nil, range
	for _, obj in pairs(workspace:GetDescendants()) do
		if obj:IsA("Model") and obj ~= char and obj:FindFirstChildOfClass("Humanoid") then
			if not specificName or (specificName and string.find(string.lower(obj.Name), string.lower(specificName))) then
				local tHumanoid = obj:FindFirstChildOfClass("Humanoid")
				local tRoot = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso") or obj:FindFirstChild("UpperTorso")
				
				if tHumanoid and tRoot and tHumanoid.Health > 0 then
					local dist = (root.Position - tRoot.Position).Magnitude
					if dist < shortDist then
						shortDist = dist
						nearest = obj
					end
				end
			end
		end
	end
	if nearest then
		return nearest:FindFirstChildOfClass("Humanoid"), (nearest:FindFirstChild("HumanoidRootPart") or nearest:FindFirstChild("Torso") or nearest:FindFirstChild("UpperTorso"))
	end
	return nil, nil
end

